"""
AutoRed — CVSS Predictor
========================

Derives a CVSS v3.1 base score for findings that have NO published CVE.

Two pieces:
  1. cvss31_base(vector)      — the exact, official CVSS v3.1 base-score
                                 equation (FIRST.org). Deterministic — the
                                 number is computed, never hand-typed.
  2. derive_cvss_from_cwe(..) — maps a CWE id to a representative v3.1
                                 vector, then runs (1) to produce a score.

This replaces the hand-typed scores in PROTOCOL_WEAKNESS_DB: instead of
storing a number someone guessed, we store a vector (the qualitative
judgement) and let the official formula compute the score.

The CWE -> vector table is intentionally COARSE: it captures the typical
worst-reasonable case for each weakness class. A service-aware or ML layer
can refine the vector later; the score computation below stays the same.
"""

import math

# ── Official CVSS v3.1 metric weights ─────────────────────────
_AV  = {'N': 0.85, 'A': 0.62, 'L': 0.55, 'P': 0.20}
_AC  = {'L': 0.77, 'H': 0.44}
_UI  = {'N': 0.85, 'R': 0.62}
_PR_UNCHANGED = {'N': 0.85, 'L': 0.62, 'H': 0.27}
_PR_CHANGED   = {'N': 0.85, 'L': 0.68, 'H': 0.50}
_CIA = {'H': 0.56, 'L': 0.22, 'N': 0.00}

# Map single-letter metric values to the words NVD uses, so derived
# findings render identically to real NVD findings in the UI.
_AV_WORD = {'N': 'NETWORK', 'A': 'ADJACENT_NETWORK',
            'L': 'LOCAL', 'P': 'PHYSICAL'}
_AC_WORD = {'L': 'LOW', 'H': 'HIGH'}
_PR_WORD = {'N': 'NONE', 'L': 'LOW', 'H': 'HIGH'}
_UI_WORD = {'N': 'NONE', 'R': 'REQUIRED'}


def _roundup(value):
    """CVSS v3.1 roundUp: ceil to one decimal place (spec appendix A)."""
    int_input = round(value * 100000)
    if int_input % 10000 == 0:
        return int_input / 100000.0
    return (math.floor(int_input / 10000) + 1) / 10.0


def severity_label(score):
    """CVSS v3.1 qualitative rating."""
    if score == 0:
        return 'NONE'
    if score < 4.0:
        return 'LOW'
    if score < 7.0:
        return 'MEDIUM'
    if score < 9.0:
        return 'HIGH'
    return 'CRITICAL'


def parse_vector(vector):
    """'CVSS:3.1/AV:N/AC:L/...' -> {'AV':'N','AC':'L',...}. Tolerant."""
    metrics = {}
    for part in str(vector).split('/'):
        if ':' not in part:
            continue
        k, v = part.split(':', 1)
        k = k.strip().upper()
        v = v.strip().upper()
        if k in ('AV', 'AC', 'PR', 'UI', 'S', 'C', 'I', 'A'):
            metrics[k] = v
    return metrics


def cvss31_base(vector):
    """
    Compute the official CVSS v3.1 base score + sub-scores from a vector.
    Returns a dict, or None if the vector is missing required metrics.
    """
    m = parse_vector(vector)
    required = ('AV', 'AC', 'PR', 'UI', 'S', 'C', 'I', 'A')
    if not all(k in m for k in required):
        return None

    scope_changed = (m['S'] == 'C')

    iss = 1 - ((1 - _CIA[m['C']]) *
               (1 - _CIA[m['I']]) *
               (1 - _CIA[m['A']]))

    if scope_changed:
        impact = 7.52 * (iss - 0.029) - 3.25 * (iss - 0.02) ** 15
    else:
        impact = 6.42 * iss

    pr = (_PR_CHANGED if scope_changed else _PR_UNCHANGED)[m['PR']]
    exploitability = 8.22 * _AV[m['AV']] * _AC[m['AC']] * pr * _UI[m['UI']]

    if impact <= 0:
        base = 0.0
    elif scope_changed:
        base = _roundup(min(1.08 * (impact + exploitability), 10))
    else:
        base = _roundup(min(impact + exploitability, 10))

    return {
        'base_score':      round(base, 1),
        'severity':        severity_label(base),
        'impact':          round(impact, 1),
        'exploitability':  round(exploitability, 1),
        'metrics':         m,
    }


def exploit_level_from_subscore(e):
    """Match the existing Easy/Moderate/Difficult banding in the app."""
    if e is None:
        return 'Unknown'
    if e >= 3.5:
        return 'Easy'
    if e >= 2.0:
        return 'Moderate'
    return 'Difficult'


