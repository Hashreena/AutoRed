# Conservative default when the CWE isn't in the table.
_DEFAULT_VECTOR = ('CVSS:3.1/AV:N/AC:L/PR:N/UI:N/S:U/C:L/I:N/A:N',
                   'Generic exposure — conservative information-disclosure baseline.')


def _normalise_cwe(cwe_id):
    """Accept 'CWE-319', 'cwe-319', '319', 'CWE-319 — name' -> 'CWE-319'."""
    if not cwe_id:
        return None
    s = str(cwe_id).upper().strip()
    # grab the first CWE-number token
    import re
    mtch = re.search(r'CWE[-\s]?(\d+)', s)
    if mtch:
        return f"CWE-{mtch.group(1)}"
    if s.isdigit():
        return f"CWE-{s}"
    return None


def derive_cvss_from_cwe(cwe_id, finding=None):
    """
    Build an nvd_best-shaped dict for a finding with no CVE, using a
    CWE-derived vector scored by the official CVSS v3.1 formula.

    The returned dict matches the shape enrich_finding/the UI expect, and
    is clearly tagged (is_derived, cvss_source, cve_id prefixed 'No CVE').
    """
    norm = _normalise_cwe(cwe_id)
    vector, rationale = CWE_CVSS_VECTORS.get(norm, _DEFAULT_VECTOR)

    calc = cvss31_base(vector)
    if not calc:
        return None

    m   = calc['metrics']
    num = norm.split('-')[1] if norm else None
    cwe_url = (
        f"https://cwe.mitre.org/data/definitions/{num}.html"
        if num else ''
    )

    return {
        'cve_id':            f"No CVE — Derived from {norm or 'CWE'}",
        'description':       rationale,
        'cvss_score':        calc['base_score'],
        'cvss_version':      '3.1',
        'cvss_severity':     calc['severity'],
        'cvss_vector':       vector,
        'published':         'N/A',
        'last_modified':     'N/A',
        'attack_vector':     _AV_WORD.get(m['AV'], m['AV']),
        'attack_complexity': _AC_WORD.get(m['AC'], m['AC']),
        'privileges_req':    _PR_WORD.get(m['PR'], m['PR']),
        'user_interaction':  _UI_WORD.get(m['UI'], m['UI']),
        'exploitability':    calc['exploitability'],
        'exploit_level':     exploit_level_from_subscore(
            calc['exploitability']
        ),
        'exploit_reason':    (
            f"Score computed from a {norm or 'generic'} baseline "
            f"vector via the CVSS 3.1 formula"
        ),
        'weaknesses':        [norm] if norm else [],
        'references':        [],
        'nvd_url':           cwe_url,
        'is_fallback':       True,
        'is_derived':        True,
        'cvss_source':       'CWE → CVSS 3.1 (computed)',
    }


